{
  "name": "open-aidoc",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node --max-old-space-size=8192 node_modules/vitepress/bin/vitepress.js build docs",
    "docs:preview": "vitepress preview docs",
    "kotlin-cn:prepare": "node sites/kotlin-cn/scripts/prepare-content.mjs",
    "kotlin-cn:dev": "pnpm kotlin-cn:prepare && vitepress dev sites/kotlin-cn",
    "kotlin-cn:build": "pnpm kotlin-cn:prepare && node --max-old-space-size=8192 node_modules/vitepress/bin/vitepress.js build sites/kotlin-cn",
    "kotlin-cn:preview": "pnpm kotlin-cn:prepare && vitepress preview sites/kotlin-cn",
    "translate": "node --import tsx --watch translate-tool/server.mjs"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    }
  },
  "keywords": [],
